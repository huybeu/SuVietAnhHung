# ── API ────────────────────────────────────────────────────────────────────────
# URL backend API. Bỏ trống → app dùng mock (dev không cần backend).
VITE_API_URL=http://localhost:3000/api

# ── App ────────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Sử Việt Anh Hùng

# ── Mock credentials (chỉ dùng khi VITE_API_URL không được set) ───────────────
# Sao chép file này thành .env và điền giá trị. KHÔNG commit .env vào git.
VITE_MOCK_SUPERADMIN_PASS=
VITE_MOCK_EDITOR_PASS=
VITE_MOCK_VIEWER_PASS=
